# Copy to .env and adjust. Never commit .env.

# Django core
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ijride

# CORS — comma-separated origins of the frontend (enforced in prod settings)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Realtime channel layer (used by prod settings only; dev uses in-memory)
REDIS_URL=redis://localhost:6379/0

# Phone normalization: local numbers starting with 0 get this country code
DEFAULT_COUNTRY_CODE=+234

# Geo provider: "stub" (dev, no keys, fake geocoding) or "mapbox"
GEO_PROVIDER=stub
MAPBOX_ACCESS_TOKEN=
# Optional geocoding bias: ISO country code + "lng,lat" proximity center
# Default centre: Yola, Adamawa State, Nigeria
GEO_COUNTRY=NG
GEO_PROXIMITY=12.4954,9.2035

# Minutes before an unaccepted ride request expires
RIDE_SEARCH_TIMEOUT_MINUTES=10

# Absolute backend URL, used to build media (vehicle photo) URLs
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Password-reset OTP delivery. "console" logs the code to the server log
# (dev/pilot); "termii" sends real SMS (set the Termii keys below).
OTP_PROVIDER=console
OTP_CODE_TTL_MINUTES=10
TERMII_API_KEY=
TERMII_SENDER_ID=IJ Ride
TERMII_BASE_URL=https://api.ng.termii.com

# JWT lifetimes
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30
